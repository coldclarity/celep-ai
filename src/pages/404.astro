---
// 404 — Seite nicht gefunden
import '@fontsource-variable/archivo/wdth.css';
import '@fontsource-variable/schibsted-grotesk';
import '@fontsource/ibm-plex-mono/400.css';
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>404 — Seite nicht gefunden · CELEP.AI</title>
<meta name="robots" content="noindex">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<meta name="theme-color" content="#0B120D">
<style>
  :root{ --bg:#0B120D; --ink:#E9EFE7; --muted:#9DAA9A; --leaf:#8FB98B; --line:rgba(143,185,139,0.18); }
  *{ box-sizing:border-box; margin:0; padding:0; }
  body{
    background:var(--bg); color:var(--ink);
    font-family:'Schibsted Grotesk Variable',sans-serif;
    min-height:100svh;
    display:flex; align-items:center; justify-content:center;
    -webkit-font-smoothing:antialiased;
  }
  .box{ text-align:center; padding:24px; }
  .code{
    font-family:'Archivo Variable',sans-serif;
    font-variation-settings:'wdth' 125;
    font-weight:850;
    font-size:clamp(80px,18vw,180px);
    line-height:1;
    color:var(--leaf);
  }
  h1{
    font-family:'Archivo Variable',sans-serif;
    font-variation-settings:'wdth' 112;
    font-weight:700;
    font-size:clamp(18px,3vw,26px);
    text-transform:uppercase; letter-spacing:0.04em;
    margin:18px 0 10px;
  }
  p{ color:var(--muted); margin-bottom:32px; }
  .btn{
    font-family:'IBM Plex Mono',monospace; font-size:12px;
    letter-spacing:0.12em; text-transform:uppercase;
    color:var(--leaf); text-decoration:none;
    border:1px solid rgba(143,185,139,0.35);
    padding:12px 22px;
    transition:border-color .3s, background .3s;
  }
  .btn:hover{ border-color:var(--leaf); background:rgba(143,185,139,0.06); }
  .btn:focus-visible{ outline:2px solid var(--leaf); outline-offset:3px; }
</style>
</head>
<body>
<div class="box">
  <div class="code">404</div>
  <h1>Seite nicht gefunden</h1>
  <p>Diese Adresse existiert nicht (mehr). Zurück zum Anfang:</p>
  <a class="btn" href="/">&larr; celep.ai</a>
</div>
</body>
</html>
