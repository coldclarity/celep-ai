</section>

<section class="kontakt" id="kontakt">
  <div class="wrap">
    <span class="mono sec-label reveal">Kontakt &amp; Netzwerk</span>
    <h2 class="reveal">Lass uns <em>vernetzen.</em></h2>
    <p class="kontakt-intro reveal">Ob Idee, Projekt, Frage oder einfach ein Gespräch — ich freue mich über jede Nachricht.</p>
    <div class="kontakt-links">
      <a class="k-link reveal" href="mailto:kontakt@celep.ai">
        <span class="k-name">E-Mail</span>
        <span class="k-handle">kontakt@celep.ai</span>
      </a>
      <a class="k-link reveal" href="https://www.linkedin.com/in/celep-burak-bayern/" target="_blank" rel="noopener">
        <span class="k-name">LinkedIn</span>
