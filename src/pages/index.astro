<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Celep.ai — Burak Celep</title>
<meta name="description" content="Burak Celep — Wertschöpfung im Interesse der Allgemeinheit. Ideen zwischen Wissenschaft, Technologie, Philosophie und Gesellschaft.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wdth,wght@0,62..125,400..900;1,62..125,400..900&family=Schibsted+Grotesk:wght@400;500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style is:global>
  :root{
    --bg:        #0B120D;
    --bg-2:      #101911;
    --ink:       #E9EBE2;
    --muted:     #97A293;
    --leaf:      #8FB98B;
    --glow:      #C8E8BC;
    --line:      rgba(210, 224, 206, 0.13);
    --max:       1120px;
    --pad:       clamp(20px, 5vw, 56px);
  }
  *{ margin:0; padding:0; box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    background:var(--bg);
    color:var(--ink);
    font-family:'Schibsted Grotesk', system-ui, sans-serif;
    font-size:17px;
    line-height:1.65;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  ::selection{ background:var(--leaf); color:var(--bg); }
  a{ color:inherit; }
  a:focus-visible, button:focus-visible{
    outline:2px solid var(--leaf);
    outline-offset:3px;
    border-radius:2px;
  }

  .wrap{ max-width:var(--max); margin:0 auto; padding-left:var(--pad); padding-right:var(--pad); }

  .mono{
    font-family:'IBM Plex Mono', monospace;
    font-size:12px;
    letter-spacing:0.16em;
    text-transform:uppercase;
    color:var(--leaf);
  }

  /* ---------- Navigation ---------- */
  nav{
    position:fixed; top:0; left:0; right:0; z-index:50;
    backdrop-filter:blur(12px);
    background:rgba(11,18,13,0.6);
    border-bottom:1px solid transparent;
    transition:border-color .4s;
  }
  nav.scrolled{ border-bottom-color:var(--line); }
  .nav-inner{
    display:flex; align-items:center; justify-content:space-between;
    height:64px;
  }
  .nav-brand{
    font-family:'Archivo', sans-serif;
    font-variation-settings:'wdth' 120;
    font-size:16px; font-weight:800; letter-spacing:0.08em;
    text-transform:uppercase;
    text-decoration:none;
  }
  .nav-brand em{ font-style:normal; color:var(--leaf); }
  .nav-links{ display:flex; gap:28px; }
  .nav-links a{
    font-size:13.5px; color:var(--muted); text-decoration:none;
    transition:color .25s;
  }
  .nav-links a:hover{ color:var(--ink); }
  @media (max-width:640px){ .nav-links{ display:none; } }

  /* ---------- Hero ---------- */
  header{
    position:relative;
    min-height:100svh;
    display:flex; flex-direction:column; justify-content:center;
    overflow:hidden;
  }
  #canopy{
    position:absolute; inset:0; width:100%; height:100%;
    display:block;
  }
  .hero-content{ position:relative; z-index:2; }
  .hero-eyebrow{ margin-bottom:28px; opacity:0; animation:rise 1s .2s forwards; }
  h1{
    font-family:'Archivo', sans-serif;
    font-variation-settings:'wdth' 125;
    font-weight:850;
    font-size:clamp(52px, 10.5vw, 148px);
    line-height:0.92;
    letter-spacing:-0.01em;
    text-transform:uppercase;
    opacity:0; animation:rise 1.1s .4s forwards;
  }
  h1 em{ font-style:normal; font-weight:850; color:var(--leaf); }
  .hero-tag{
    margin-top:36px;
    max-width:520px;
    opacity:0; animation:rise 1s .7s forwards;
  }
  .hero-tag p:first-child{
    font-family:'Archivo', sans-serif;
    font-variation-settings:'wdth' 110;
    font-weight:650;
    font-size:clamp(19px, 2.4vw, 24px);
    line-height:1.3;
    color:var(--ink);
  }
  .hero-tag p:last-child{
    margin-top:14px; color:var(--muted); font-size:16px;
  }
  .scroll-cue{
    position:absolute; bottom:36px; left:var(--pad); z-index:2;
    display:flex; align-items:center; gap:12px;
    color:var(--muted); font-family:'IBM Plex Mono',monospace; font-size:11px;
    letter-spacing:0.14em; text-transform:uppercase;
    opacity:0; animation:rise 1s 1.2s forwards;
  }
  .scroll-cue::before{
    content:""; width:1px; height:42px; background:var(--leaf);
    animation:drip 2.4s ease-in-out infinite;
    transform-origin:top;
  }
  @keyframes rise{ from{ opacity:0; transform:translateY(22px); } to{ opacity:1; transform:none; } }
  @keyframes drip{ 0%,100%{ transform:scaleY(0.35); opacity:.4 } 50%{ transform:scaleY(1); opacity:1 } }

  /* ---------- Sections ---------- */
  section{ padding:clamp(90px, 12vw, 150px) 0; }
  .sec-label{ display:block; margin-bottom:22px; }
  h2{
    font-family:'Archivo', sans-serif;
    font-variation-settings:'wdth' 125;
    font-weight:800;
    font-size:clamp(30px, 4.4vw, 50px);
    line-height:1.02;
    letter-spacing:-0.005em;
    text-transform:uppercase;
    max-width:16ch;
  }
  h2 em{ font-style:normal; color:var(--leaf); }

  /* Haltung */
  .haltung-grid{
    display:grid;
    grid-template-columns:minmax(0,5fr) minmax(0,6fr);
    gap:clamp(40px, 6vw, 90px);
    align-items:start;
  }
  .portrait-frame{
    position:relative;
  }
  .portrait-frame img{
    width:100%; display:block;
    filter:grayscale(28%) contrast(1.02);
    border:1px solid var(--line);
  }
  .portrait-frame::after{
    content:""; position:absolute; inset:0;
    background:linear-gradient(180deg, transparent 55%, rgba(11,18,13,0.55));
    pointer-events:none;
  }
  .portrait-caption{
    margin-top:14px; color:var(--muted);
    font-family:'IBM Plex Mono',monospace; font-size:11.5px; letter-spacing:0.1em;
  }
  .haltung-text h2{ margin-bottom:30px; }
  .haltung-text p{ color:var(--muted); margin-bottom:20px; max-width:56ch; }
  .haltung-text p strong{ color:var(--ink); font-weight:500; }
  @media (max-width:820px){
    .haltung-grid{ grid-template-columns:1fr; }
    .portrait-frame{ max-width:420px; }
  }

  /* Themenfelder */
  .themen{ background:var(--bg-2); border-top:1px solid var(--line); border-bottom:1px solid var(--line); }
  .themen h2{ margin-bottom:54px; }
  .feld{
    display:grid;
    grid-template-columns:minmax(0,4fr) minmax(0,7fr);
    gap:20px;
    padding:26px 0;
    border-top:1px solid var(--line);
    align-items:baseline;
    transition:padding-left .35s ease;
  }
  .feld:last-child{ border-bottom:1px solid var(--line); }
  .feld:hover{ padding-left:14px; }
  .feld-name{
    font-family:'Archivo', sans-serif;
    font-variation-settings:'wdth' 118;
    font-size:clamp(17px, 2.1vw, 22px);
    font-weight:750;
    text-transform:uppercase;
    letter-spacing:0.04em;
    transition:color .3s;
  }
  .feld:hover .feld-name{ color:var(--glow); }
  .feld-desc{ color:var(--muted); font-size:15.5px; max-width:52ch; }
  @media (max-width:640px){
    .feld{ grid-template-columns:1fr; gap:6px; }
  }

  /* Statement */
  .statement{ text-align:left; }
  .statement blockquote{
    font-family:'Archivo', sans-serif;
    font-variation-settings:'wdth' 112;
    font-weight:680;
    font-size:clamp(23px, 3.6vw, 38px);
    line-height:1.22;
    max-width:26ch;
    color:var(--ink);
  }
  .statement blockquote span{ color:var(--leaf); }
  .statement cite{
    display:block; margin-top:30px;
    font-family:'IBM Plex Mono',monospace; font-style:normal;
    font-size:12px; letter-spacing:0.14em; text-transform:uppercase;
    color:var(--muted);
  }

  /* Projekte */
  .projekte h2{ margin-bottom:54px; }
  .projekt{
    display:grid;
    grid-template-columns:minmax(0,4fr) minmax(0,5fr) minmax(0,2fr);
    gap:20px; align-items:baseline;
    padding:26px 0;
    border-top:1px solid var(--line);
    text-decoration:none;
    transition:padding-left .35s ease;
  }
  .projekt:last-of-type{ border-bottom:1px solid var(--line); }
  .projekt:hover{ padding-left:14px; }
  .projekt-name{
    font-family:'Archivo', sans-serif;
    font-variation-settings:'wdth' 118;
    font-size:clamp(16px,1.9vw,20px);
    font-weight:750;
    text-transform:uppercase;
    letter-spacing:0.04em;
    transition:color .3s;
  }
  .projekt:hover .projekt-name{ color:var(--glow); }
  .projekt-desc{ color:var(--muted); font-size:15px; }
  .projekt-status{
    justify-self:end;
    font-family:'IBM Plex Mono',monospace; font-size:11px;
    letter-spacing:0.12em; text-transform:uppercase;
    color:var(--leaf);
    border:1px solid rgba(143,185,139,0.35);
    padding:5px 12px; border-radius:0;
    white-space:nowrap;
  }
  .projekt-status.dim{ color:var(--muted); border-color:var(--line); }
  @media (max-width:700px){
    .projekt{ grid-template-columns:1fr; gap:8px; }
    .projekt-status{ justify-self:start; }
  }

  /* Kontakt */
  .kontakt{ background:var(--bg-2); border-top:1px solid var(--line); }
  .kontakt h2{ margin-bottom:24px; }
  .kontakt-intro{ color:var(--muted); max-width:48ch; margin-bottom:50px; }
  .kontakt-links{ display:flex; flex-direction:column; }
  .k-link{
    display:flex; align-items:baseline; justify-content:space-between;
    gap:20px;
    padding:22px 0;
    border-top:1px solid var(--line);
    text-decoration:none;
    transition:padding-left .35s ease;
  }
  .k-link:last-child{ border-bottom:1px solid var(--line); }
  .k-link:hover{ padding-left:14px; }
  .k-name{
    font-family:'Archivo', sans-serif;
    font-variation-settings:'wdth' 118;
    font-size:clamp(17px,2.2vw,23px); font-weight:750;
    text-transform:uppercase;
    letter-spacing:0.04em;
    transition:color .3s;
  }
  .k-link:hover .k-name{ color:var(--glow); }
  .k-handle{
    font-family:'IBM Plex Mono',monospace; font-size:12.5px;
    color:var(--muted); letter-spacing:0.04em;
    transition:color .3s;
  }
  .k-link:hover .k-handle{ color:var(--leaf); }

  /* Footer */
  footer{
    padding:44px 0 50px;
    border-top:1px solid var(--line);
  }
  .footer-inner{
    display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap;
    color:var(--muted); font-size:13px;
  }
  .footer-inner a{ color:var(--muted); text-decoration:none; margin-left:22px; transition:color .25s; }
  .footer-inner a:hover{ color:var(--ink); }

  /* Scroll-Reveals */
  .reveal{ opacity:0; transform:translateY(28px); transition:opacity .9s ease, transform .9s ease; }
  .reveal.in{ opacity:1; transform:none; }

  @media (prefers-reduced-motion: reduce){
    *, *::before, *::after{ animation:none !important; transition:none !important; }
    .hero-eyebrow, h1, .hero-tag, .scroll-cue{ opacity:1; }
    .reveal{ opacity:1; transform:none; }
    html{ scroll-behavior:auto; }
  }
</style>
</head>
<body>

<nav id="nav">
  <div class="wrap nav-inner">
    <a class="nav-brand" href="#top">Celep<em>.ai</em></a>
    <div class="nav-links">
      <a href="#haltung">Haltung</a>
      <a href="#themen">Themenfelder</a>
      <a href="#projekte">Projekte</a>
      <a href="#kontakt">Kontakt</a>
    </div>
  </div>
</nav>

<header id="top">
  <canvas id="canopy" aria-hidden="true"></canvas>
  <div class="wrap hero-content">
    <span class="mono hero-eyebrow">Burak Celep — Gersthofen · Augsburg</span>
    <h1>Celep<em>.ai</em></h1>
    <div class="hero-tag">
      <p>Wertschöpfung im Interesse der Allgemeinheit.</p>
      <p>Ideen zwischen Wissenschaft, Technologie, Philosophie und Gesellschaft — angetrieben von Erkenntnis, nicht von Rendite.</p>
    </div>
  </div>
  <div class="scroll-cue">Scrollen</div>
</header>

<section id="haltung">
  <div class="wrap haltung-grid">
    <div class="portrait-frame reveal">
      <img src="data:image/jpeg;base64," alt="Portrait von Burak Celep" width="760" height="626">
      <div class="portrait-caption">Burak Celep</div>
    </div>
    <div class="haltung-text">
      <span class="mono sec-label reveal">Haltung</span>
      <h2 class="reveal">Glückseligkeit durch <em>Erkenntnis.</em></h2>
      <p class="reveal">Mein Antrieb ist nicht das finanzielle Interesse. Es ist die Überzeugung, dass Arbeit dann Sinn stiftet, wenn sie <strong>Probleme im Interesse der Allgemeinheit löst</strong> — wenn am Ende etwas entsteht, das über den Einzelnen hinaus Wert schafft.</p>
      <p class="reveal">Die Grundlage meines Denkens ist einfach: <strong>Stetiges Lernen und das Ergründen neuer Erkenntnisse</strong> sind für mich kein Mittel zum Zweck, sondern Bestandteil meiner Persönlichkeit — und die verlässlichste Quelle von Glückseligkeit, die ich kenne.</p>
      <p class="reveal">Diese Seite macht meine Person sichtbar. Für Menschen, die ähnliche Fragen stellen, Netzwerke bilden oder einfach ins Gespräch kommen wollen: Ich kann mich für nahezu alles begeistern — schreiben Sie mir.</p>
    </div>
  </div>
</section>

<section class="themen" id="themen">
  <div class="wrap">
    <span class="mono sec-label reveal">Themenfelder</span>
    <h2 class="reveal">Was mich <em>bewegt.</em></h2>
    <div class="felder">
      <div class="feld reveal">
        <div class="feld-name">Wissenschaft</div>
        <div class="feld-desc">Methoden, Evidenz und der Mut, die eigenen Annahmen zu prüfen.</div>
      </div>
      <div class="feld reveal">
        <div class="feld-name">Gesundheit</div>
        <div class="feld-desc">Ganzheitlich gedacht — Körper, Psyche und das Umfeld, das beide prägt.</div>
      </div>
      <div class="feld reveal">
        <div class="feld-name">Technologie</div>
        <div class="feld-desc">Werkzeuge, die Menschen erweitern, statt sie zu ersetzen.</div>
      </div>
      <div class="feld reveal">
        <div class="feld-name">Philosophie</div>
        <div class="feld-desc">Die Fragen hinter den Antworten — und das Aushalten von Ungewissheit.</div>
      </div>
      <div class="feld reveal">
        <div class="feld-name">Psychologie</div>
        <div class="feld-desc">Wie wir entscheiden, fühlen und uns verändern.</div>
      </div>
      <div class="feld reveal">
        <div class="feld-name">Gesellschaft</div>
        <div class="feld-desc">Sozialwissenschaft im Konkreten: die Herausforderungen Deutschlands als Gestaltungsauftrag.</div>
      </div>
    </div>
  </div>
</section>

<section class="statement">
  <div class="wrap">
    <blockquote class="reveal">
      Die Herausforderungen, vor denen wir in Deutschland stehen, sind kein Grund zur Resignation — <span>sie sind eine Einladung, Wertschöpfung neu zu denken.</span>
    </blockquote>
    <cite class="reveal">Burak Celep</cite>
  </div>
</section>

<section class="projekte" id="projekte">
  <div class="wrap">
    <span class="mono sec-label reveal">Projekte &amp; Ideen</span>
    <h2 class="reveal">Woran ich <em>arbeite.</em></h2>
    <div style="height:54px"></div>
    <a class="projekt reveal" href="#top">
      <div class="projekt-name">Celep.ai</div>
      <div class="projekt-desc">Diese Plattform — Identität, Ideen und ein offener Kanal für Vernetzung.</div>
      <div class="projekt-status">Live</div>
    </a>
    <a class="projekt reveal" href="https://github.com/coldclarity" target="_blank" rel="noopener">
      <div class="projekt-name">CEO-Lösung</div>
      <div class="projekt-desc">Repository auf GitHub — Konzeptphase.</div>
      <div class="projekt-status dim">In Arbeit</div>
    </a>
    <a class="projekt reveal" href="https://github.com/coldclarity" target="_blank" rel="noopener">
      <div class="projekt-name">ScreentimeBridge</div>
      <div class="projekt-desc">Repository auf GitHub — derzeit privat.</div>
      <div class="projekt-status dim">In Arbeit</div>
    </a>
