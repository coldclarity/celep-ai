---
// celep.ai — Visitenkarte / Single-Page-Landing
import '@fontsource-variable/archivo/wdth.css';
import '@fontsource-variable/schibsted-grotesk';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';

// ── Frei editierbar ────────────────────────────────────────
const NAME    = "Burak Celep";
const ROLE    = "Consultant — B2B & Enterprise Solutions";
const TAGLINE = "Strategische B2B-Beratung an der Schnittstelle von Technologie und Geschäft. Im kostenlosen 15-Minuten-Erstgespräch stellen Sie mir Ihr Problem vor — ich zeige Ihnen den Lösungsweg."; // ← anpassen
const EMAIL   = "Kontakt@celep.ai";
const BOOKING_URL = "https://cal.com/burak-celep/15min"; // ← deinen echten Buchungslink eintragen (Cal.com oder Calendly)
const LOCATION = "Gersthofen · Augsburg · Bayern";

const secondary = [
  { label: "GitHub",    url: "https://github.com/coldclarity" },
  { label: "ORCID",     url: "https://orcid.org/0009-0006-4523-1488" },
  { label: "Instagram", url: "https://www.instagram.com/oudrow/" },
  { label: "YouTube",   url: "https://www.youtube.com/@data-oparation" },
  { label: "Spotify",   url: "https://open.spotify.com/user/31wpsomklo34kwnvq5ffgayvcecy" },
];
const LINKEDIN = "https://www.linkedin.com/in/celep-burak-bayern";

const sameAs = [LINKEDIN, ...secondary.map(s => s.url)];
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": NAME,
  "jobTitle": "Consultant — B2B & Enterprise Solutions",
  "url": "https://celep.ai/",
  "email": `mailto:${EMAIL}`,
  "address": { "@type": "PostalAddress", "addressLocality": "Gersthofen", "addressRegion": "Bayern", "addressCountry": "DE" },
  "sameAs": sameAs
};
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="canonical" href="https://celep.ai/">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/favicon.ico" sizes="32x32">
<link rel="icon" href="/favicon-32.png" type="image/png">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<meta name="theme-color" content="#0B120D">
<title>Burak Celep — Consultant für B2B & Enterprise Solutions</title>
<meta name="description" content="Burak Celep — Consultant für B2B & Enterprise Solutions. Strategische Beratung an der Schnittstelle von Technologie und Geschäft.">

<meta property="og:type" content="profile">
<meta property="og:site_name" content="Celep.ai">
<meta property="og:locale" content="de_DE">
<meta property="og:url" content="https://celep.ai/">
<meta property="og:title" content="Burak Celep — Consultant für B2B & Enterprise Solutions">
<meta property="og:description" content="Strategische Beratung an der Schnittstelle von Technologie und Geschäft.">
<meta property="og:image" content="https://celep.ai/images/og.jpg">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Burak Celep — Consultant für B2B & Enterprise Solutions">
<meta name="twitter:description" content="Strategische Beratung an der Schnittstelle von Technologie und Geschäft.">
<meta name="twitter:image" content="https://celep.ai/images/og.jpg">

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<style is:global>
  :root{
    --bg:    #0B120D;  --bg-2: #101911;  --ink: #E9EBE2;
    --muted: #97A293;  --leaf: #8FB98B;  --glow: #C8E8BC;
    --line:  rgba(210, 224, 206, 0.13);
    --pad:   clamp(22px, 5vw, 56px);
  }
  *{ margin:0; padding:0; box-sizing:border-box; }
  body{
    background:var(--bg); color:var(--ink);
    font-family:'Schibsted Grotesk Variable', system-ui, sans-serif;
    font-size:17px; line-height:1.6; -webkit-font-smoothing:antialiased;
    min-height:100dvh; display:flex; flex-direction:column;
    overflow-x:hidden;
  }
  ::selection{ background:var(--leaf); color:var(--bg); }
  a{ color:inherit; }
  a:focus-visible{ outline:2px solid var(--leaf); outline-offset:3px; border-radius:3px; }

  .bg-glow{ position:fixed; inset:0; pointer-events:none; z-index:0;
    background:
      radial-gradient(58% 42% at 50% 0%, rgba(143,185,139,0.11), transparent 72%),
      radial-gradient(40% 30% at 50% 100%, rgba(143,185,139,0.05), transparent 70%);
  }

  .card{
    position:relative; z-index:1; flex:1;
    display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center;
    padding:56px var(--pad) 28px; gap:0;
    animation:rise .8s cubic-bezier(.22,.61,.36,1) both;
  }
  @keyframes rise{ from{ opacity:0; transform:translateY(16px); } to{ opacity:1; transform:none; } }
  @media (prefers-reduced-motion: reduce){ .card{ animation:none; } }

  .avatar{
    width:96px; height:96px; border-radius:50%; object-fit:cover;
    border:1px solid var(--line); background:var(--bg-2);
    box-shadow:0 0 0 6px rgba(143,185,139,0.06);
  }
  .name{
    font-family:'Archivo Variable', sans-serif; font-variation-settings:'wdth' 110;
    font-weight:800; font-size:clamp(34px, 6.4vw, 58px); line-height:1.0;
    letter-spacing:-0.02em; text-transform:uppercase; margin-top:26px;
  }
  .name em{ font-style:normal; color:var(--leaf); }
  .role{
    font-family:'IBM Plex Mono', monospace; font-size:12.5px; letter-spacing:0.14em;
    text-transform:uppercase; color:var(--leaf); margin-top:16px;
  }
  .tagline{ color:var(--muted); max-width:52ch; margin-top:20px; font-size:clamp(15.5px,1.9vw,18px); }

  .actions{ display:flex; gap:14px; flex-wrap:wrap; justify-content:center; margin-top:32px; }
  .btn{
    display:inline-flex; align-items:center; gap:10px;
    font-family:'IBM Plex Mono', monospace; font-size:13px; letter-spacing:0.1em; text-transform:uppercase;
    text-decoration:none; padding:14px 24px; border-radius:999px; transition:background .25s, transform .25s, border-color .25s, color .25s;
  }
  .btn.primary{ background:var(--leaf); color:var(--bg); border:1px solid var(--leaf); }
  .btn.primary:hover{ background:var(--glow); border-color:var(--glow); transform:translateY(-2px); }
  .btn.ghost{ background:transparent; color:var(--ink); border:1px solid var(--line); }
  .btn.ghost:hover{ border-color:var(--leaf); color:var(--leaf); transform:translateY(-2px); }
  .btn svg{ width:15px; height:15px; }

  .secondary{ display:flex; gap:10px 20px; flex-wrap:wrap; justify-content:center; margin-top:28px; }
  .secondary a{ font-size:13.5px; color:var(--muted); text-decoration:none; transition:color .25s; }
  .secondary a:hover{ color:var(--leaf); }

  .loc{ font-family:'IBM Plex Mono', monospace; font-size:11.5px; letter-spacing:0.12em; text-transform:uppercase; color:var(--muted); margin-top:30px; }

  .legal{ position:relative; z-index:1; text-align:center; padding:18px var(--pad) 26px; font-size:12px; color:var(--muted); }
  .legal a{ color:var(--muted); text-decoration:none; margin:0 9px; transition:color .25s; }
  .legal a:hover{ color:var(--ink); }
</style>
</head>
<body>
  <div class="bg-glow" aria-hidden="true"></div>

  <main class="card">
    <img class="avatar" src="/images/avatar.jpg" alt={`Porträt von ${NAME}`} width="96" height="96" decoding="async">
    <h1 class="name">{NAME}</h1>
    <p class="role">{ROLE}</p>
    <p class="tagline">{TAGLINE}</p>

    <div class="actions">
      <a class="btn primary" href={BOOKING_URL} target="_blank" rel="noopener noreferrer">
        Termin buchen · 15 Min
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
      </a>
      <a class="btn ghost" href={`mailto:${EMAIL}`}>
        E-Mail
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="1"/><polyline points="3 7 12 13 21 7"/></svg>
      </a>
      <a class="btn ghost" href={LINKEDIN} target="_blank" rel="me noopener noreferrer">
        LinkedIn
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>
    </div>

    <nav class="secondary" aria-label="Weitere Kanäle">
      {secondary.map((s) => (
        <a href={s.url} target="_blank" rel="me noopener noreferrer">{s.label}</a>
      ))}
    </nav>

    <p class="loc">{LOCATION}</p>
  </main>

  <footer class="legal">
    <a href="/impressum">Impressum</a>·<a href="/datenschutz">Datenschutz</a>
  </footer>
</body>
</html>
