---
// Über mich — celep.ai
import '@fontsource-variable/archivo/wdth.css';
import '@fontsource-variable/schibsted-grotesk';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';

// ── Frei editierbare Inhalte ───────────────────────────────
const eckdaten = [
  { label: "Standort",  value: "Gersthofen · Augsburg, Bayern" },
  { label: "Fokus",     value: "Wissenschaft · Technologie · Philosophie · Gesellschaft" },
  { label: "Antrieb",   value: "Erkenntnis statt Rendite" },
  { label: "Sprachen",  value: "Deutsch · Englisch" },        // ← anpassen
];

const prinzipien = [
  { t: "Ehrlich vor gefällig",          d: "Direkte Kommunikation ist die höchste Form von Respekt." },
  { t: "Charakter durch Handlung",      d: "Wir definieren uns über Taten, nicht über Worte." },
  { t: "Stetiges Lernen",               d: "So lange fragen, bis man es wirklich verstanden hat." },
  { t: "Wert über den Einzelnen hinaus", d: "Arbeit, die etwas schafft, das größer ist als ich selbst." },
];
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="canonical" href="https://celep.ai/ueber-mich">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/favicon.ico" sizes="32x32">
<link rel="icon" href="/favicon-32.png" type="image/png">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<meta name="theme-color" content="#0B120D">
<title>Über mich — Burak Celep</title>
<meta name="description" content="Wer hinter celep.ai steht: Burak Celep über seinen Antrieb, seine Haltung und die Überzeugung, dass Arbeit Sinn stiftet, wenn sie Probleme im Interesse der Allgemeinheit löst.">

<meta property="og:type" content="profile">
<meta property="og:site_name" content="Celep.ai">
<meta property="og:locale" content="de_DE">
<meta property="og:url" content="https://celep.ai/ueber-mich">
<meta property="og:title" content="Über mich — Burak Celep">
<meta property="og:description" content="Der Mensch hinter celep.ai — Antrieb, Haltung und ein Denken, das über den Einzelnen hinaus Wert schafft.">
<meta property="og:image" content="https://celep.ai/images/og.jpg">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Über mich — Burak Celep">
<meta name="twitter:description" content="Der Mensch hinter celep.ai.">
<meta name="twitter:image" content="https://celep.ai/images/og.jpg">

<noscript><style>.reveal{ opacity:1 !important; transform:none !important; }</style></noscript>
<style is:global>
  :root{
    --bg:    #0B120D;  --bg-2: #101911;  --ink: #E9EBE2;
    --muted: #97A293;  --leaf: #8FB98B;  --glow: #C8E8BC;
    --line:  rgba(210, 224, 206, 0.13);
    --max:   1120px;   --pad:  clamp(20px, 5vw, 56px);
  }
  *{ margin:0; padding:0; box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    background:var(--bg); color:var(--ink);
    font-family:'Schibsted Grotesk Variable', system-ui, sans-serif;
    font-size:17px; line-height:1.65; -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  ::selection{ background:var(--leaf); color:var(--bg); }
  a{ color:inherit; }
  a:focus-visible, button:focus-visible{ outline:2px solid var(--leaf); outline-offset:3px; border-radius:2px; }
  .wrap{ max-width:var(--max); margin:0 auto; padding-left:var(--pad); padding-right:var(--pad); }
  .mono{
    font-family:'IBM Plex Mono', monospace; font-size:12px;
    letter-spacing:0.16em; text-transform:uppercase; color:var(--leaf);
  }
  h1,h2,h3{ font-family:'Archivo Variable', sans-serif; }

  /* ---------- Navigation ---------- */
  nav{
    position:fixed; top:0; left:0; right:0; z-index:50;
    backdrop-filter:blur(12px); background:rgba(11,18,13,0.6);
    border-bottom:1px solid transparent; transition:border-color .4s;
  }
  nav.scrolled{ border-bottom-color:var(--line); }
  .nav-inner{ display:flex; align-items:center; justify-content:space-between; height:64px; }
  .nav-brand{
    font-family:'Archivo Variable', sans-serif; font-variation-settings:'wdth' 120;
    font-size:16px; font-weight:800; letter-spacing:0.08em;
    text-transform:uppercase; text-decoration:none;
  }
  .nav-brand em{ font-style:normal; color:var(--leaf); }
  .nav-links{ display:flex; gap:28px; align-items:center; }
  .nav-links a{ font-size:13.5px; color:var(--muted); text-decoration:none; transition:color .25s; }
  .nav-links a:hover{ color:var(--ink); }
  .nav-links a[aria-current="page"]{ color:var(--leaf); }
  .nav-toggle{ display:none; background:none; border:0; cursor:pointer; width:42px; height:42px; padding:9px; color:var(--ink); }
  .nav-toggle svg{ width:100%; height:100%; }
  .nav-toggle .ico-close{ display:none; }
  .nav-toggle[aria-expanded="true"] .ico-open{ display:none; }
  .nav-toggle[aria-expanded="true"] .ico-close{ display:block; }
  .nav-panel{ max-height:0; overflow:hidden; background:rgba(11,18,13,0.97); border-bottom:1px solid transparent; transition:max-height .4s ease, border-color .4s; }
  .nav-panel.open{ max-height:420px; border-bottom-color:var(--line); }
  .nav-panel a{ display:block; padding:15px var(--pad); font-size:15px; color:var(--muted); text-decoration:none; border-top:1px solid var(--line); }
  .nav-panel a:first-child{ border-top:0; }
  .nav-panel a:hover{ color:var(--ink); background:rgba(143,185,139,0.05); }
  .nav-panel a[aria-current="page"]{ color:var(--leaf); }

  /* ---------- Reveal-Animation ---------- */
  .reveal{ opacity:0; transform:translateY(28px); transition:opacity .9s ease, transform .9s ease; }
  .reveal.in{ opacity:1; transform:none; }
  @media (prefers-reduced-motion: reduce){ .reveal{ opacity:1; transform:none; transition:none; } }

  /* ---------- Über-mich: Hero ---------- */
  .about-hero{ padding:148px 0 56px; }
  .about-hero h1{
    font-variation-settings:'wdth' 112; font-weight:800;
    font-size:clamp(44px, 8.4vw, 104px); line-height:0.95;
    letter-spacing:-0.02em; text-transform:uppercase; margin-top:20px;
  }
  .about-hero h1 em{ font-style:normal; color:var(--leaf); }
  .about-hero .lead{ max-width:600px; color:var(--muted); font-size:clamp(17px,2.1vw,21px); margin-top:30px; }

  /* ---------- Porträt + Statement ---------- */
  .intro-grid{ display:grid; grid-template-columns:minmax(0,5fr) minmax(0,6fr); gap:clamp(20px,3.4vw,48px); align-items:stretch; padding:36px 0 64px; }
  .portrait-card{ position:relative; }
  .portrait-card img{
    width:100%; height:auto; display:block;
    aspect-ratio:4/5; object-fit:cover; object-position:50% 20%;
    border:1px solid var(--line); filter:grayscale(22%) contrast(1.02); background:var(--bg-2);
  }
  .statement{
    background:var(--bg-2); border:1px solid var(--line);
    padding:clamp(28px,4vw,52px); display:flex; flex-direction:column; justify-content:center;
  }
  .statement .qmark{ font-family:'Archivo Variable',sans-serif; font-weight:800; font-size:58px; line-height:0.5; color:var(--leaf); }
  .statement blockquote{
    font-family:'Archivo Variable',sans-serif; font-variation-settings:'wdth' 100;
    font-weight:700; font-size:clamp(22px,3vw,33px); line-height:1.16;
    letter-spacing:-0.01em; margin-top:26px;
  }
  .statement cite{ font-style:normal; color:var(--muted); font-size:14px; margin-top:24px; }

  /* ---------- Bio + Eckdaten ---------- */
  .bio-grid{ display:grid; grid-template-columns:minmax(0,7fr) minmax(0,5fr); gap:clamp(32px,5vw,72px); padding:64px 0; border-top:1px solid var(--line); align-items:start; }
  .bio h2{ font-variation-settings:'wdth' 105; font-weight:800; font-size:clamp(26px,3.4vw,38px); line-height:1.05; letter-spacing:-0.01em; }
  .bio p{ color:var(--muted); margin-top:20px; max-width:62ch; }
  .bio p strong{ color:var(--ink); font-weight:600; }
  .eckdaten dl{ border-top:1px solid var(--line); }
  .eckdaten .row{ padding:18px 0; border-bottom:1px solid var(--line); }
  .eckdaten dt{ font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--leaf); }
  .eckdaten dd{ margin-top:7px; color:var(--ink); font-size:15.5px; }

  /* ---------- Prinzipien ---------- */
  .prinzipien{ padding:64px 0; border-top:1px solid var(--line); }
  .prinzipien > .head{ max-width:560px; }
  .prinzipien h2{ font-variation-settings:'wdth' 105; font-weight:800; font-size:clamp(26px,3.4vw,38px); line-height:1.05; letter-spacing:-0.01em; margin-top:14px; }
  .prinzipien-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:1px; background:var(--line); border:1px solid var(--line); margin-top:36px; }
  .prinzip{ background:var(--bg); padding:clamp(24px,3vw,38px); }
  .prinzip .n{ font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--leaf); letter-spacing:0.1em; }
  .prinzip h3{ font-variation-settings:'wdth' 100; font-weight:700; font-size:clamp(18px,2vw,22px); margin-top:14px; }
  .prinzip p{ color:var(--muted); margin-top:10px; font-size:15.5px; }

  /* ---------- CTA ---------- */
  .cta-band{ padding:72px 0 104px; border-top:1px solid var(--line); text-align:center; }
  .cta-band h2{ font-variation-settings:'wdth' 108; font-weight:800; font-size:clamp(30px,5vw,58px); line-height:1.0; letter-spacing:-0.02em; text-transform:uppercase; }
  .cta-band p{ color:var(--muted); margin-top:18px; }
  .btn{
    display:inline-flex; align-items:center; gap:10px; margin-top:32px;
    font-family:'IBM Plex Mono',monospace; font-size:13px; letter-spacing:0.12em; text-transform:uppercase;
    color:var(--bg); background:var(--leaf); text-decoration:none;
    padding:15px 26px; border-radius:999px; transition:background .25s, transform .25s;
  }
  .btn:hover{ background:var(--glow); transform:translateY(-2px); }
  .btn svg{ width:15px; height:15px; }

  /* ---------- Footer ---------- */
  footer{ border-top:1px solid var(--line); }
  .footer-inner{ display:flex; flex-wrap:wrap; gap:16px; justify-content:space-between; align-items:center; padding-top:28px; padding-bottom:28px; font-size:13px; color:var(--muted); }
  .footer-inner a{ color:var(--muted); text-decoration:none; margin-left:20px; transition:color .25s; }
  .footer-inner a:hover{ color:var(--ink); }

  /* ---------- Responsiv ---------- */
  @media (max-width:820px){
    .nav-links{ display:none; }
    .nav-toggle{ display:block; }
    .intro-grid{ grid-template-columns:1fr; }
    .portrait-card{ max-width:460px; }
    .bio-grid{ grid-template-columns:1fr; gap:40px; }
    .prinzipien-grid{ grid-template-columns:1fr; }
    .footer-inner a:first-child{ margin-left:0; }
  }
</style>
</head>
<body>

<nav id="nav">
  <div class="wrap nav-inner">
    <a class="nav-brand" href="/">Celep<em>.ai</em></a>
    <div class="nav-links">
      <a href="/#haltung">Haltung</a>
      <a href="/#themen">Themenfelder</a>
      <a href="/ueber-mich" aria-current="page">Über mich</a>
      <a href="/magazin">Magazin</a>
      <a href="/#projekte">Projekte</a>
      <a href="/#kontakt">Kontakt</a>
    </div>
    <button class="nav-toggle" id="navToggle" type="button"
            aria-label="Menü öffnen" aria-expanded="false" aria-controls="navPanel">
      <svg class="ico-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="7" x2="21" y2="7"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="17" x2="21" y2="17"></line>
      </svg>
      <svg class="ico-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="5" y1="5" x2="19" y2="19"></line><line x1="19" y1="5" x2="5" y2="19"></line>
      </svg>
    </button>
  </div>
  <div class="nav-panel" id="navPanel">
    <a href="/#haltung">Haltung</a>
    <a href="/#themen">Themenfelder</a>
    <a href="/ueber-mich" aria-current="page">Über mich</a>
    <a href="/magazin">Magazin</a>
    <a href="/#projekte">Projekte</a>
    <a href="/#kontakt">Kontakt</a>
  </div>
</nav>

<main>
  <!-- Hero -->
  <section class="about-hero">
    <div class="wrap">
      <span class="mono reveal">Über mich · Gersthofen · Augsburg</span>
      <h1 class="reveal">Der Mensch hinter <em>celep.ai</em></h1>
      <p class="lead reveal">Kein Lebenslauf in Stichpunkten — sondern das, was mich antreibt: Neugier, Ehrlichkeit und die Überzeugung, dass gute Arbeit über den Einzelnen hinaus Wert schafft.</p>
    </div>
  </section>

  <!-- Porträt + Statement -->
  <section>
    <div class="wrap intro-grid">
      <div class="portrait-card reveal">
        <img src="/images/portrait.jpg" alt="Porträt von Burak Celep" width="800" height="1000" loading="eager" decoding="async">
      </div>
      <figure class="statement reveal">
        <span class="qmark" aria-hidden="true">&ldquo;</span>
        <blockquote>Arbeit stiftet dann Sinn, wenn sie Probleme im Interesse der Allgemeinheit löst — wenn am Ende etwas entsteht, das über den Einzelnen hinaus Wert schafft.</blockquote>
        <cite>— Burak Celep</cite>
      </figure>
    </div>
  </section>

  <!-- Bio + Eckdaten -->
  <section>
    <div class="wrap bio-grid">
      <div class="bio reveal">
        <h2>Über Burak Celep</h2>
        <p>Mein Antrieb ist nicht das finanzielle Interesse, sondern die <strong>Überzeugung, dass Arbeit dann Sinn stiftet</strong>, wenn sie Probleme im Interesse der Allgemeinheit löst. Ich bewege mich gern an den Schnittstellen — zwischen Wissenschaft, Technologie, Philosophie und Gesellschaft — und suche dort nach Ideen, die etwas Bleibendes schaffen.</p>
        <p>Die Grundlage meines Denkens ist einfach: <strong>stetiges Lernen und das Ergründen neuer Erkenntnisse</strong> sind für mich kein Mittel zum Zweck, sondern Bestandteil meiner Persönlichkeit — und die verlässlichste Quelle von Glückseligkeit, die ich kenne.</p>
        <p>Diese Seite macht meine Person sichtbar. Für Menschen, die ähnliche Fragen stellen, Netzwerke bilden oder einfach ins Gespräch kommen wollen: Ich kann mich für nahezu alles begeistern — <strong>schreiben Sie mir.</strong></p>
      </div>
      <aside class="eckdaten reveal" aria-label="Eckdaten">
        <dl>
          {eckdaten.map((e) => (
            <div class="row">
              <dt>{e.label}</dt>
              <dd>{e.value}</dd>
            </div>
          ))}
          <div class="row">
            <dt>Kontakt</dt>
            <dd><a href="/#kontakt" style="color:var(--leaf);text-decoration:none;">Schreiben Sie mir →</a></dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <!-- Prinzipien -->
  <section class="prinzipien">
    <div class="wrap">
      <div class="head reveal">
        <span class="mono">Wie ich denke</span>
        <h2>Vier Überzeugungen, die meine Arbeit tragen</h2>
      </div>
      <div class="prinzipien-grid">
        {prinzipien.map((p, i) => (
          <article class="prinzip reveal">
            <span class="n">0{i + 1}</span>
            <h3>{p.t}</h3>
            <p>{p.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="wrap">
      <span class="mono reveal">Ins Gespräch kommen</span>
      <h2 class="reveal">Reden wir.</h2>
      <p class="reveal">Eine Idee, ein Projekt, eine Frage — oder einfach ein gutes Gespräch.</p>
      <a class="btn reveal" href="/#kontakt">
        Kontakt aufnehmen
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  </section>
</main>

<footer>
  <div class="wrap footer-inner">
    <span>© 2026 Burak Celep · Celep.ai</span>
    <span>
      <a href="/ueber-mich">Über mich</a>
      <a href="/magazin">Magazin</a>
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
    </span>
  </div>
</footer>

<script is:inline>
/* Mobiles Menü */
(function(){
  const toggle = document.getElementById('navToggle');
  const panel  = document.getElementById('navPanel');
  if(!toggle || !panel) return;
  function setOpen(open){
    panel.classList.toggle('open', open);
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
  }
  toggle.addEventListener('click', function(){ setOpen(!panel.classList.contains('open')); });
  panel.querySelectorAll('a').forEach(function(a){ a.addEventListener('click', function(){ setOpen(false); }); });
})();

/* Nav-Rahmen beim Scrollen */
(function(){
  const nav = document.getElementById('nav');
  if(!nav) return;
  const onScroll = function(){ nav.classList.toggle('scrolled', window.scrollY > 8); };
  onScroll(); window.addEventListener('scroll', onScroll, { passive:true });
})();

/* Reveal beim Scrollen */
(function(){
  const els = document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){ els.forEach(function(el){ el.classList.add('in'); }); return; }
  const io = new IntersectionObserver(function(entries){
    entries.forEach(function(en){ if(en.isIntersecting){ en.target.classList.add('in'); io.unobserve(en.target); } });
  }, { threshold:0.12, rootMargin:'0px 0px -8% 0px' });
  els.forEach(function(el){ io.observe(el); });
})();
</script>
</body>
</html>
