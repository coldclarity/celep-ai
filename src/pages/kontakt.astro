---
// Kontakt — celep.ai
import '@fontsource-variable/archivo/wdth.css';
import '@fontsource-variable/schibsted-grotesk';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';

const EMAIL = "Kontakt@celep.ai";

const social = [
  { name: "LinkedIn", handle: "celep-burak-bayern", url: "https://www.linkedin.com/in/celep-burak-bayern" },
  { name: "GitHub",   handle: "coldclarity",        url: "https://github.com/coldclarity" },
  { name: "Instagram",handle: "@oudrow",            url: "https://www.instagram.com/oudrow/" },
  { name: "YouTube",  handle: "@data-oparation",    url: "https://www.youtube.com/@data-oparation" },
  { name: "Spotify",  handle: "Profil",             url: "https://open.spotify.com/user/31wpsomklo34kwnvq5ffgayvcecy" },
  { name: "ORCID",    handle: "0009-0006-4523-1488", url: "https://orcid.org/0009-0006-4523-1488" },
];

const betreffe = [
  "Allgemeine Anfrage",
  "Projekt oder Zusammenarbeit",
  "Austausch & Vernetzung",
  "Presse & Medien",
  "Sonstiges",
];
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="canonical" href="https://celep.ai/kontakt">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/favicon.ico" sizes="32x32">
<link rel="icon" href="/favicon-32.png" type="image/png">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<meta name="theme-color" content="#0B120D">
<title>Kontakt — Burak Celep</title>
<meta name="description" content="Kontakt zu Burak Celep — für Projekte, Austausch und Vernetzung. Per E-Mail, über die sozialen Kanäle oder direkt über das Formular.">

<meta property="og:type" content="website">
<meta property="og:site_name" content="Celep.ai">
<meta property="og:locale" content="de_DE">
<meta property="og:url" content="https://celep.ai/kontakt">
<meta property="og:title" content="Kontakt — Burak Celep">
<meta property="og:description" content="Reden wir — für Projekte, Austausch und Vernetzung.">
<meta property="og:image" content="https://celep.ai/images/og.jpg">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Kontakt — Burak Celep">
<meta name="twitter:description" content="Reden wir.">
<meta name="twitter:image" content="https://celep.ai/images/og.jpg">

<noscript><style>.reveal{ opacity:1 !important; transform:none !important; }</style></noscript>
<style is:global>
  :root{
    --bg:    #0B120D;  --bg-2: #101911;  --ink: #E9EBE2;
    --muted: #97A293;  --leaf: #8FB98B;  --glow: #C8E8BC;
    --line:  rgba(210, 224, 206, 0.13);
    --max:   1120px;   --pad:  clamp(20px, 5vw, 56px);
  }
  *{ margin:0; padding:0; box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    background:var(--bg); color:var(--ink);
    font-family:'Schibsted Grotesk Variable', system-ui, sans-serif;
    font-size:17px; line-height:1.65; -webkit-font-smoothing:antialiased; overflow-x:hidden;
  }
  ::selection{ background:var(--leaf); color:var(--bg); }
  a{ color:inherit; }
  a:focus-visible, button:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible{ outline:2px solid var(--leaf); outline-offset:3px; border-radius:2px; }
  .wrap{ max-width:var(--max); margin:0 auto; padding-left:var(--pad); padding-right:var(--pad); }
  .mono{ font-family:'IBM Plex Mono', monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; color:var(--leaf); }
  h1,h2,h3{ font-family:'Archivo Variable', sans-serif; }

  /* Navigation */
  nav{ position:fixed; top:0; left:0; right:0; z-index:50; backdrop-filter:blur(12px); background:rgba(11,18,13,0.6); border-bottom:1px solid transparent; transition:border-color .4s; }
  nav.scrolled{ border-bottom-color:var(--line); }
  .nav-inner{ display:flex; align-items:center; justify-content:space-between; height:64px; }
  .nav-brand{ font-family:'Archivo Variable', sans-serif; font-variation-settings:'wdth' 120; font-size:16px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; }
  .nav-brand em{ font-style:normal; color:var(--leaf); }
  .nav-links{ display:flex; gap:28px; align-items:center; }
  .nav-links a{ font-size:13.5px; color:var(--muted); text-decoration:none; transition:color .25s; }
  .nav-links a:hover{ color:var(--ink); }
  .nav-links a[aria-current="page"]{ color:var(--leaf); }
  .nav-toggle{ display:none; background:none; border:0; cursor:pointer; width:42px; height:42px; padding:9px; color:var(--ink); }
  .nav-toggle svg{ width:100%; height:100%; }
  .nav-toggle .ico-close{ display:none; }
  .nav-toggle[aria-expanded="true"] .ico-open{ display:none; }
  .nav-toggle[aria-expanded="true"] .ico-close{ display:block; }
  .nav-panel{ max-height:0; overflow:hidden; background:rgba(11,18,13,0.97); border-bottom:1px solid transparent; transition:max-height .4s ease, border-color .4s; }
  .nav-panel.open{ max-height:420px; border-bottom-color:var(--line); }
  .nav-panel a{ display:block; padding:15px var(--pad); font-size:15px; color:var(--muted); text-decoration:none; border-top:1px solid var(--line); }
  .nav-panel a:first-child{ border-top:0; }
  .nav-panel a:hover{ color:var(--ink); background:rgba(143,185,139,0.05); }
  .nav-panel a[aria-current="page"]{ color:var(--leaf); }

  /* Reveal */
  .reveal{ opacity:0; transform:translateY(28px); transition:opacity .9s ease, transform .9s ease; }
  .reveal.in{ opacity:1; transform:none; }
  @media (prefers-reduced-motion: reduce){ .reveal{ opacity:1; transform:none; transition:none; } }

  /* Hero */
  .k-hero{ padding:148px 0 24px; }
  .k-hero h1{ font-variation-settings:'wdth' 112; font-weight:800; font-size:clamp(52px, 11vw, 140px); line-height:0.92; letter-spacing:-0.02em; text-transform:uppercase; margin-top:20px; }
  .k-hero h1 em{ font-style:normal; color:var(--leaf); }
  .k-hero .lead{ max-width:560px; color:var(--muted); font-size:clamp(17px,2.1vw,21px); margin-top:28px; }

  /* Kontakt-Spalten */
  .contact-grid{ display:grid; grid-template-columns:repeat(3, 1fr); gap:clamp(28px,4vw,56px); padding:48px 0 16px; }
  .cblock .mono{ display:block; margin-bottom:16px; }
  .cblock a.big{ font-size:clamp(18px,2.2vw,22px); color:var(--ink); text-decoration:none; transition:color .25s; }
  .cblock a.big:hover{ color:var(--leaf); }
  .cblock p{ color:var(--muted); font-size:15.5px; margin-top:6px; }
  .social-list{ list-style:none; display:flex; flex-direction:column; }
  .social-list a{ display:flex; align-items:baseline; justify-content:space-between; gap:16px; padding:12px 0; border-bottom:1px solid var(--line); color:var(--ink); text-decoration:none; transition:color .25s; }
  .social-list a:hover{ color:var(--leaf); }
  .social-list .handle{ font-family:'IBM Plex Mono', monospace; font-size:12px; color:var(--muted); }

  /* Formular */
  .form-grid{ display:grid; grid-template-columns:minmax(0,4fr) minmax(0,7fr); gap:clamp(32px,5vw,72px); padding:64px 0 96px; margin-top:40px; border-top:1px solid var(--line); align-items:start; }
  .form-grid h2{ font-variation-settings:'wdth' 106; font-weight:800; font-size:clamp(28px,4vw,46px); line-height:1.0; letter-spacing:-0.01em; text-transform:uppercase; }
  .form-grid .sub{ color:var(--muted); margin-top:16px; max-width:34ch; }
  .field{ margin-top:26px; }
  .field label{ display:block; font-family:'IBM Plex Mono', monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--leaf); margin-bottom:10px; }
  .field input, .field select, .field textarea{ width:100%; background:transparent; border:0; border-bottom:1px solid var(--line); color:var(--ink); font-family:inherit; font-size:16px; padding:11px 0; transition:border-color .25s; }
  .field input::placeholder, .field textarea::placeholder{ color:rgba(151,162,147,0.55); }
  .field input:focus, .field select:focus, .field textarea:focus{ outline:none; border-bottom-color:var(--leaf); }
  .field textarea{ resize:vertical; min-height:130px; }
  .field select{ appearance:none; cursor:pointer; }
  .field select option{ background:var(--bg-2); color:var(--ink); }
  .consent{ display:flex; gap:12px; align-items:flex-start; margin-top:28px; font-size:14px; color:var(--muted); }
  .consent input{ margin-top:4px; accent-color:var(--leaf); width:16px; height:16px; flex-shrink:0; }
  .consent a{ color:var(--leaf); }
  .btn{ display:inline-flex; align-items:center; gap:10px; margin-top:30px; font-family:'IBM Plex Mono', monospace; font-size:13px; letter-spacing:0.12em; text-transform:uppercase; color:var(--bg); background:var(--leaf); border:0; cursor:pointer; text-decoration:none; padding:15px 26px; border-radius:999px; transition:background .25s, transform .25s; }
  .btn:hover{ background:var(--glow); transform:translateY(-2px); }
  .btn svg{ width:15px; height:15px; }
  .form-status{ margin-top:18px; font-size:14px; color:var(--leaf); min-height:1.3em; }

  /* Footer */
  footer{ border-top:1px solid var(--line); }
  .footer-inner{ display:flex; flex-wrap:wrap; gap:16px; justify-content:space-between; align-items:center; padding-top:28px; padding-bottom:28px; font-size:13px; color:var(--muted); }
  .footer-inner a{ color:var(--muted); text-decoration:none; margin-left:20px; transition:color .25s; }
  .footer-inner a:hover{ color:var(--ink); }

  @media (max-width:820px){
    .nav-links{ display:none; } .nav-toggle{ display:block; }
    .contact-grid{ grid-template-columns:1fr; gap:36px; }
    .form-grid{ grid-template-columns:1fr; gap:32px; }
    .footer-inner a:first-child{ margin-left:0; }
  }
</style>
</head>
<body>

<nav id="nav">
  <div class="wrap nav-inner">
    <a class="nav-brand" href="/">Celep<em>.ai</em></a>
    <div class="nav-links">
      <a href="/#haltung">Haltung</a>
      <a href="/#themen">Themenfelder</a>
      <a href="/ueber-mich">Über mich</a>
      <a href="/magazin">Magazin</a>
      <a href="/#projekte">Projekte</a>
      <a href="/kontakt" aria-current="page">Kontakt</a>
    </div>
    <button class="nav-toggle" id="navToggle" type="button" aria-label="Menü öffnen" aria-expanded="false" aria-controls="navPanel">
      <svg class="ico-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="7" x2="21" y2="7"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="17" x2="21" y2="17"></line></svg>
      <svg class="ico-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="5" x2="19" y2="19"></line><line x1="19" y1="5" x2="5" y2="19"></line></svg>
    </button>
  </div>
  <div class="nav-panel" id="navPanel">
    <a href="/#haltung">Haltung</a>
    <a href="/#themen">Themenfelder</a>
    <a href="/ueber-mich">Über mich</a>
    <a href="/magazin">Magazin</a>
    <a href="/#projekte">Projekte</a>
    <a href="/kontakt" aria-current="page">Kontakt</a>
  </div>
</nav>

<main>
  <!-- Hero -->
  <section class="k-hero">
    <div class="wrap">
      <span class="mono reveal">Kontakt · Gersthofen · Augsburg</span>
      <h1 class="reveal">Reden <em>wir.</em></h1>
      <p class="lead reveal">Eine Idee, ein Projekt, eine Frage — oder einfach ein gutes Gespräch. Ich freue mich, von dir zu hören.</p>
    </div>
  </section>

  <!-- Kontaktdaten + Social -->
  <section>
    <div class="wrap contact-grid">
      <div class="cblock reveal">
        <span class="mono">Direkt erreichen</span>
        <a class="big" href={`mailto:${EMAIL}`}>{EMAIL}</a>
        <p>Antwort meist innerhalb weniger Tage.</p>
      </div>
      <div class="cblock reveal">
        <span class="mono">Standort</span>
        <p style="color:var(--ink);font-size:clamp(18px,2.2vw,22px);">Gersthofen · Augsburg</p>
        <p>Bayern, Deutschland</p>
      </div>
      <div class="cblock reveal">
        <span class="mono">Folgen &amp; vernetzen</span>
        <ul class="social-list">
          {social.map((s) => (
            <li><a href={s.url} target="_blank" rel="me noopener noreferrer"><span>{s.name}</span><span class="handle">{s.handle}</span></a></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Formular -->
  <section>
    <div class="wrap form-grid">
      <div class="reveal">
        <h2>Schreib mir</h2>
        <p class="sub">Fülle kurz das Formular aus — es öffnet eine vorbereitete E-Mail an mich.</p>
      </div>
      <form id="kontaktForm" class="reveal" novalidate>
        <div class="field">
          <label for="f-name">Name</label>
          <input id="f-name" type="text" autocomplete="name" placeholder="Dein Name" required>
        </div>
        <div class="field">
          <label for="f-email">E-Mail</label>
          <input id="f-email" type="email" autocomplete="email" placeholder="du@beispiel.de" required>
        </div>
        <div class="field">
          <label for="f-subject">Betreff</label>
          <select id="f-subject">
            <option value="">Bitte wählen …</option>
            {betreffe.map((b) => <option value={b}>{b}</option>)}
          </select>
        </div>
        <div class="field">
          <label for="f-message">Nachricht</label>
          <textarea id="f-message" placeholder="Worum geht es?" required></textarea>
        </div>
        <label class="consent">
          <input id="f-consent" type="checkbox" required>
          <span>Ich bin mit der Verarbeitung meiner Angaben gemäß der <a href="/datenschutz">Datenschutzerklärung</a> einverstanden.</span>
        </label>
        <button class="btn" type="submit">
          Nachricht senden
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </button>
        <p class="form-status" id="formStatus" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</main>

<footer>
  <div class="wrap footer-inner">
    <span>© 2026 Burak Celep · Celep.ai</span>
    <span>
      <a href="/ueber-mich">Über mich</a>
      <a href="/magazin">Magazin</a>
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
    </span>
  </div>
</footer>

<script is:inline>
/* Mobiles Menü */
(function(){
  var toggle = document.getElementById('navToggle'), panel = document.getElementById('navPanel');
  if(!toggle || !panel) return;
  function setOpen(open){ panel.classList.toggle('open', open); toggle.setAttribute('aria-expanded', open?'true':'false'); toggle.setAttribute('aria-label', open?'Menü schließen':'Menü öffnen'); }
  toggle.addEventListener('click', function(){ setOpen(!panel.classList.contains('open')); });
  panel.querySelectorAll('a').forEach(function(a){ a.addEventListener('click', function(){ setOpen(false); }); });
})();

/* Nav-Rahmen beim Scrollen */
(function(){ var nav=document.getElementById('nav'); if(!nav) return; var f=function(){ nav.classList.toggle('scrolled', window.scrollY>8); }; f(); window.addEventListener('scroll', f, {passive:true}); })();

/* Reveal */
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){ els.forEach(function(el){ el.classList.add('in'); }); return; }
  var io=new IntersectionObserver(function(en){ en.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } }); }, {threshold:0.12, rootMargin:'0px 0px -8% 0px'});
  els.forEach(function(el){ io.observe(el); });
})();

/* Formular → vorbereitete E-Mail (kein Server nötig) */
(function(){
  var form=document.getElementById('kontaktForm'); if(!form) return;
  var status=document.getElementById('formStatus');
  form.addEventListener('submit', function(e){
    e.preventDefault();
    var name=document.getElementById('f-name').value.trim();
    var email=document.getElementById('f-email').value.trim();
    var subject=document.getElementById('f-subject').value;
    var message=document.getElementById('f-message').value.trim();
    var consent=document.getElementById('f-consent').checked;
    if(!name || !email || !message){ status.textContent='Bitte Name, E-Mail und Nachricht ausfüllen.'; return; }
    if(!consent){ status.textContent='Bitte der Datenschutzerklärung zustimmen.'; return; }
    var betreff = subject ? subject : 'Nachricht über celep.ai';
    var body = 'Name: '+name+'\nE-Mail: '+email+'\n\n'+message;
    status.textContent='E-Mail-Programm wird geöffnet …';
    window.location.href = 'mailto:Kontakt@celep.ai?subject='+encodeURIComponent(betreff)+'&body='+encodeURIComponent(body);
  });
})();
</script>
</body>
</html>
